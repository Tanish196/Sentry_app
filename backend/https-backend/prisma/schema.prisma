// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      UserRole @default(USER)
  avatar    String?
  address   String?

  locationLogs      LocationLog[]
  emergencyContacts EmergencyContact[]
  itineraries       Itinerary[]
  bookingVisits     BookingVisit[]
  supportTickets    SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocationLog {
  id        String   @id @default(uuid())
  userId    String

  latitude  Float
  longitude Float
  accuracy  Float?
  speed     Float?
  heading   Float?

  riskScore Int
  source    LocationSource

  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmergencyContact {
  id       String @id @default(uuid())
  userId   String

  name     String
  phone    String
  email    String?
  relation String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Itinerary {
  id            String   @id @default(uuid())
  userId        String

  startLocation String
  endLocation   String
  startTime     DateTime
  endTime       DateTime
  status        ItineraryStatus
  checklist     Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
}

enum LocationSource {
  GPS
  NETWORK
}

model BookingPartner {
  id          String   @id @default(uuid())
  name        String
  description String
  url         String   // HTTPS only — validated in backend
  logoUrl     String?
  category    String   // e.g., "flights", "hotels", "buses", "trains"
  isVerified  Boolean  @default(true)
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // higher = shown first

  visits      BookingVisit[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingVisit {
  id          String   @id @default(uuid())
  userId      String
  partnerId   String
  durationMs  Int      // time spent — detect accidental opens (<5s)

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner     BookingPartner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  visitedAt   DateTime @default(now())

  @@index([userId])
  @@index([partnerId])
}

enum ItineraryStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

model SupportTicket {
  id            String   @id @default(uuid())
  ticketNumber  Int      @unique @default(autoincrement())
  userId        String?
  name          String
  email         String
  subject       String
  message       String
  status        TicketStatus @default(OPEN)

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

// ── Explore Tab Models ──
model SafetyAlert {
  id            String        @id @default(uuid())
  title         String
  description   String
  severity      AlertSeverity
  affectedAreas String[]
  issuedBy      String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  expiresAt     DateTime?
}

enum AlertSeverity {
  CRITICAL
  CAUTION
  INFO
}

model SafetyZone {
  id          String    @id @default(uuid())
  areaName    String
  safetyScore Float
  zoneLevel   ZoneLevel
  polygon     Json?     // GeoJSON polygon boundaries
  notes       String?
  updatedAt   DateTime  @default(now()) @updatedAt
}

enum ZoneLevel {
  SAFE
  MODERATE
  AVOID
}